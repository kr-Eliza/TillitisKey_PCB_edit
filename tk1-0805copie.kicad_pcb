	(generator_version "9.0")
	(general
		(thickness 0.8)
		(legacy_teardrops no)
	)
	(paper "A4")
	(layers
		(0 "F.Cu" power)
		(2 "B.Cu" signal)
		(9 "F.Adhes" user "F.Adhesive")
		(11 "B.Adhes" user "B.Adhesive")
